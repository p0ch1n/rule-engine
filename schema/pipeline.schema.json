{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rule-engine/schema/pipeline.schema.json",
  "title": "Pipeline Configuration",
  "description": "JSON Schema for rule-engine pipeline DAG configuration",
  "type": "object",
  "required": ["version", "metadata", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version (semver-lite)"
    },
    "metadata": {
      "type": "object",
      "required": ["toolId", "classList"],
      "additionalProperties": false,
      "properties": {
        "toolId": {
          "type": "string",
          "minLength": 1
        },
        "classList": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/NodeConfig" },
      "minItems": 1
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/EdgeConfig" }
    }
  },
  "definitions": {
    "Position": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "NodeConfig": {
      "type": "object",
      "required": ["id", "type", "position", "config"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["filter", "logic", "relation", "merge", "detection", "image_analysis", "input"]
        },
        "position": { "$ref": "#/definitions/Position" },
        "functionId": {
          "type": "string",
          "description": "Optional identifier reserved for function/step binding"
        },
        "config": {
          "oneOf": [
            { "$ref": "#/definitions/FilterConfig" },
            { "$ref": "#/definitions/LogicConfig" },
            { "$ref": "#/definitions/RelationConfig" },
            { "$ref": "#/definitions/MergeConfig" },
            { "$ref": "#/definitions/InputConfig" }
          ]
        }
      }
    },
    "FilterCondition": {
      "type": "object",
      "required": ["className", "field", "operator", "threshold"],
      "additionalProperties": false,
      "properties": {
        "className": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "enum": ["confidence", "width", "height", "area"] },
        "operator": { "type": "string", "enum": ["gt", "gte", "lt", "lte", "eq"] },
        "threshold": { "type": "number", "minimum": 0 }
      }
    },
    "FilterConfig": {
      "type": "object",
      "required": ["conditions"],
      "additionalProperties": false,
      "properties": {
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/definitions/FilterCondition" },
          "minItems": 1
        },
        "logic": {
          "type": "string",
          "enum": ["AND", "OR"],
          "default": "AND",
          "description": "AND: obj must pass ALL conditions for its class; OR: at least one"
        }
      }
    },
    "LogicConfig": {
      "type": "object",
      "required": ["operation", "conditions"],
      "additionalProperties": false,
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["AND", "OR"]
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["className"],
            "additionalProperties": false,
            "properties": {
              "className": { "type": "string", "minLength": 1 },
              "minCount": { "type": "integer", "minimum": 1, "default": 1 },
              "negate": { "type": "boolean", "default": false, "description": "When true, condition is satisfied when count < minCount (class absent)" }
            }
          },
          "minItems": 1
        },
        "triggerLabel": {
          "type": "string",
          "description": "Label included in trigger metadata when condition fires"
        }
      }
    },
    "RelationConfig": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["self_join", "cross_join"],
          "description": "self_join: single input pairwise; cross_join: two inputs"
        },
        "relationType": {
          "type": "string",
          "enum": ["iou", "distance", "contains", "centroid_distance"],
          "default": "iou"
        },
        "threshold": {
          "type": "number",
          "minimum": 0,
          "description": "IoU or distance threshold for relation to qualify"
        },
        "filterClassA": {
          "type": "string",
          "description": "Only use boxes of this class for side A. Leave empty to use all classes."
        },
        "filterClassB": {
          "type": "string",
          "description": "Only use boxes of this class for side B. Leave empty to use all classes."
        },
        "outputClassName": {
          "type": "string",
          "description": "Class name assigned to each output relation Object. Leave empty to use the auto-generated 'A+B' label."
        },
        "offset": {
          "$ref": "#/definitions/ObjectOffset",
          "description": "Geometric offset applied to the generated relation Object"
        },
        "scale": {
          "$ref": "#/definitions/ObjectScale"
        }
      }
    },
    "MergeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topK": {
          "type": "integer",
          "minimum": 1,
          "default": 1000,
          "description": "Max Objects retained after merge, ordered by confidence desc"
        }
      }
    },
    "ObjectOffset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dx": { "type": "number", "default": 0 },
        "dy": { "type": "number", "default": 0 },
        "dw": { "type": "number", "default": 0 },
        "dh": { "type": "number", "default": 0 }
      }
    },
    "ObjectScale": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sx": { "type": "number", "minimum": 0, "default": 1.0 },
        "sy": { "type": "number", "minimum": 0, "default": 1.0 },
        "sw": { "type": "number", "minimum": 0, "default": 1.0 },
        "sh": { "type": "number", "minimum": 0, "default": 1.0 }
      }
    },
    "InputFile": {
      "type": "object",
      "required": ["filename", "data"],
      "additionalProperties": false,
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "data": { "type": "string", "minLength": 1, "description": "Base64 data URI of the uploaded file" }
      }
    },
    "InputConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["images", "video", "external"],
          "default": "images",
          "description": "images/video: base64 files embedded in config (UI/prototype); external: images injected via execute_frame(images=[...]) at runtime (deployment)"
        },
        "files": {
          "type": "array",
          "items": { "$ref": "#/definitions/InputFile" },
          "default": []
        },
        "frameStep": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Extract every Nth frame (video mode only)"
        },
        "maxFrames": {
          "type": "integer",
          "minimum": 1,
          "default": 100,
          "description": "Maximum number of frames to extract from video"
        }
      }
    },
    "EdgeConfig": {
      "type": "object",
      "required": ["id", "source", "sourcePort", "target", "targetPort"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "Source node id"
        },
        "sourcePort": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "description": "Target node id"
        },
        "targetPort": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
